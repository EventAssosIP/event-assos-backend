{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200", // Angular
      "http://localhost:3000", // React
      "http://127.0.0.1:5500" // LiveServer
    ]
  },

  "ConnectionStrings": {
    "Default": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=master;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
  },

  // Attention, ne JAMAIS stocker des informations sensibles dans ce fichier en développement/production !
  "JwtSettings": {
    "SecretKey": "VotreClefSecreteTrèsLongueEtComplexeDeMinimum32Caractères!", // La clef secrète pour signer le token
    "Issuer": "EventAssosAPI", // Le nom de qui émet le token
    "Audience": "EventAssosMember", // Le nom de qui va utiliser le token
    "ExpirationMinutes": 30 // La durée de validité du token en minutes
  }
}
